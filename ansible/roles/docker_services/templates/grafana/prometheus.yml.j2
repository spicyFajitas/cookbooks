global:
  scrape_interval: 1m

scrape_configs:
  - job_name: 'prometheus'
    static_configs:
      - targets: ['localhost:9090']
  - job_name: 'docker-host'
    static_configs:
      - targets: ['10.100.10.20:9100']
  - job_name: 'pve'
    static_configs:
      - targets:
        - 10.100.10.10
    metrics_path: /pve
    params:
      module: [default]
    relabel_configs:
      - source_labels: [__address__]
        target_label: __param_target
      - source_labels: [__param_target]
        target_label: instance
      - target_label: __address__
        replacement: 10.100.10.20:9221
  - job_name: 'magic-edhrec-analyzer'
    # k3s pod, scraped from outside the cluster via the NodePort Service
    # (kubernetes/apps/magic/03-service.yaml) -- no in-cluster Prometheus
    # Operator/ServiceMonitor needed for a single app.
    scrape_interval: 15s
    static_configs:
      - targets: ['10.100.10.12:30852']
